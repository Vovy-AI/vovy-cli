{
  "name": "vovy",
  "version": "0.1.0",
  "description": "Free, forever, drop-in MCP server + skill pack that teaches non-technical founders to vibe code safely. npx vovy install",
  "license": "MIT",
  "type": "module",
  "bin": {
    "vovy": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@vovy/host-detect": "workspace:*",
    "@vovy/skills": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
